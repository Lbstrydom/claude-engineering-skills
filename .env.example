# Required: Your OpenAI API key (needs GPT-5.4 access)
OPENAI_API_KEY=sk-...

# Optional: Override model (default: gpt-5.4)
# OPENAI_AUDIT_MODEL=gpt-5.4

# Optional: Reasoning effort for quality passes (default: high)
# Options: low, medium, high, xhigh
# OPENAI_AUDIT_REASONING=high

# Optional: Hard ceiling for output tokens per pass (default: 32000)
# The adaptive sizing stays below this — only change if you're hitting API limits
# OPENAI_AUDIT_MAX_TOKENS=32000

# Optional: Hard ceiling for timeout per pass in ms (default: 300000 = 5 min)
# OPENAI_AUDIT_TIMEOUT_MS=300000

# Optional: Backend file count threshold for splitting into sub-passes (default: 12)
# If your backend has >12 files referenced in the plan, it auto-splits into routes + services
# OPENAI_AUDIT_SPLIT_THRESHOLD=12

# ── Gemini (Independent Final Reviewer — Step 7) ──────────────────────────

# Optional: Gemini API key for independent final review after Claude-GPT convergence
# If not set, final review falls back to Claude Opus if ANTHROPIC_API_KEY is set
GEMINI_API_KEY=AIza...

# Optional: Override Gemini model (default: gemini-3.1-pro-preview)
# GEMINI_REVIEW_MODEL=gemini-3.1-pro-preview

# Optional: Gemini max output tokens (default: 32000, uses streaming internally)
# GEMINI_REVIEW_MAX_TOKENS=32000

# Optional: Gemini timeout in ms (default: 120000 = 2 min)
# GEMINI_REVIEW_TIMEOUT_MS=120000

# ── Context Brief (auto-generated at audit start) ───────────────────────────

# Optional: Override brief generation model (Gemini Flash → Claude Haiku fallback)
# BRIEF_MODEL_GEMINI=gemini-2.5-flash
# BRIEF_MODEL_CLAUDE=claude-haiku-4-5-20251001

# Optional: Anthropic API key for Claude Haiku brief fallback
# Also used for Step 7 Claude Opus final-review fallback when GEMINI_API_KEY is missing
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override Claude Opus model for Step 7 fallback
# CLAUDE_FINAL_REVIEW_MODEL=claude-opus-4-1

# ── Learning Store (cross-session persistence — optional) ─────────────────
#
# This project supports multiple storage backends for debt ledger, audit
# history, bandit arms, and false-positive patterns. Local files always work
# as the no-config default. For cross-session / cross-repo / team learning,
# set ONE of the options below. See docs/setup/storage-backends.md.
#
#   Backend         | Env var                | Scope
#   ----------------|------------------------|---------------------------------
#   local-only      | (nothing — default)    | Single audit session, .audit/
#   local-shared    | AUDIT_STORE=sqlite     | Cross-repo on one machine
#   github          | AUDIT_STORE=github     | Per-repo, committed data
#   postgres        | AUDIT_STORE=postgres   | Self-hosted / cloud Postgres
#   supabase        | AUDIT_STORE=supabase   | BYO Supabase
#
# AUDIT_STORE=

# Supabase (optional — bring your own project, see docs/setup/supabase.md)
# SUPABASE_AUDIT_URL=https://<your-project-ref>.supabase.co
# SUPABASE_AUDIT_ANON_KEY=<your-anon-key>

# Self-hosted Postgres (optional — AWS RDS, Azure DB, Railway, Neon, etc.)
# AUDIT_STORE_POSTGRES_URL=postgres://user:pass@host:5432/dbname
#
# Supabase Pro — dedicated pooler (higher throughput for bulk operations)
# Switch to AUDIT_STORE=postgres and use the dedicated pooler connection string
# from your project dashboard → Connect settings → Transaction mode (port 6543).
# The shared pooler (port 5432) works fine for light usage; dedicated is faster
# for bulk writes and avoids shared-pooler contention.
# AUDIT_STORE=postgres
# AUDIT_STORE_POSTGRES_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Local cross-repo SQLite DB (optional — one file, all repos on this machine)
# AUDIT_STORE_SQLITE_PATH=~/.audit-loop/shared.db
